# This file has been generated to exclude unnecessary files from being uploaded
# to Google Cloud Build / App Engine / Cloud Run during deployment.

# Include all patterns from .gitignore
#!include:.gitignore

# Exclude git directories
.git/
.github/

# Exclude Terraform configuration files (not needed for running the application container)
*.tf
*.tfvars
.terraform/
.terraform.lock.hcl

# Exclude documentation and markdown files
*.md
LICENSE
